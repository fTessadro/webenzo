---
import "../styles/global.css";
import Navbar from "../components/common/navbar.astro";
import Footer from "../components/common/footer.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link
			rel="icon"
			type="image/png"
			href={`${import.meta.env.BASE_URL}favicon.png`}
		/>
		<meta name="generator" content={Astro.generator} />
		<title>Innova Dental Studio</title>
		<meta
			name="description"
			content="Especialistas en implantes, ortodoncia y estética dental. Vení a Innova Dental Studio y lográ tu mejor sonrisa con tecnología de vanguardia y atención personalizada."
		/>
		<link rel="canonical" href="https://www.innovadentalstudio.com.ar/" />

		<!-- <meta name="author" content="Innova Dental Studio" />
		<meta name="theme-color" content="#000000" />
		<meta name="robots" content="index, follow" /> -->
	</head>
	<body>
		<div class="bg-[#F0F0F0]">
			<Navbar />
			<slot />

			<Footer />
		</div>
	</body>
</html>
