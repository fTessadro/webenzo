---
import { getImage } from "astro:assets";
import frenteImgRaw from "../../assets/img/frente.JPG";
import recepcionImgRaw from "../../assets/img/recepcion.JPG";
import consultorioImgRaw from "../../assets/img/consultorio.JPG";

const frenteImg = await getImage({ src: frenteImgRaw, format: "webp" });
const recepcionImg = await getImage({ src: recepcionImgRaw, format: "webp" });
const consultorioImg = await getImage({
  src: consultorioImgRaw,
  format: "webp",
});
---

<header
  class="relative h-screen min-h-[600px] w-full overflow-hidden flex items-center bg-[#0B253A]"
>
  <!-- Contenedor de imágenes de fondo animadas -->
  <div class="absolute inset-0 z-0">
    <div
      class="carousel-image absolute inset-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1000 opacity-100"
      style={`background-image: url('${frenteImg.src}')`}
      data-index="0"
    >
    </div>
    <div
      class="carousel-image absolute inset-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1000 opacity-0"
      style={`background-image: url('${recepcionImg.src}')`}
      data-index="1"
    >
    </div>
    <div
      class="carousel-image absolute inset-0 bg-cover bg-center bg-no-repeat transition-opacity duration-1000 opacity-0"
      style={`background-image: url('${consultorioImg.src}')`}
      data-index="2"
    >
    </div>
  </div>

  <!-- Dark overlay with blue tint -->
  <div
    class="absolute inset-0 z-0 bg-[#0B253A]/50 mix-blend-multiply pointer-events-none"
  >
  </div>
  <div
    class="absolute inset-0 z-0 bg-gradient-to-r from-[#0B253A]/70 to-[#0B253A]/20 pointer-events-none"
  >
  </div>

  <!-- Bottom white fade -->
  <div
    class="absolute bottom-0 left-0 w-full h-32 z-0 bg-gradient-to-t from-white to-transparent pointer-events-none"
  >
  </div>

  <!-- Decorative Background Text (Watermark) -->
  <div
    class="absolute top-[40%] left-0 w-full z-0 transform -translate-y-1/2 pointer-events-none select-none flex justify-center opacity-10"
  >
    <span
      class="text-[12vw] font-bold text-[#0B253A] whitespace-nowrap tracking-tighter mix-blend-color-burn"
      >Innova Dental Studio</span
    >
  </div>

  <main
    class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 flex flex-col items-start justify-center text-left pt-20"
  >
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#1e405a]/60 border border-[#2b5372]/50 backdrop-blur-sm mb-6"
    >
      <div class="w-1.5 h-1.5 rounded-full bg-[#00b4b6]"></div>
      <span class="text-xs md:text-sm font-medium text-gray-200"
        >Odontología integral de excelencia</span
      >
    </div>

    <!-- Title -->
    <h1
      class="text-5xl md:text-6xl lg:text-7xl font-serif font-bold text-white mb-6 leading-tight"
    >
      Innova Dental <span class="text-[#00b4b6]">Studio</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="text-base md:text-xl text-gray-300 mb-10 max-w-2xl leading-relaxed"
    >
      Un espacio diseñado para brindar atencion odontologica integral, con
      especial enfoque en <strong class="text-white font-semibold"
        >estetica</strong
      > e <strong class="text-white font-semibold">implantologia</strong>.
    </p>

    <!-- Buttons -->
    <div class="flex flex-wrap items-center gap-4 mb-20 md:mb-24">
      <a
        href="https://calendar.app.google/NSkNNH7vMJoUf1bi7"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#00b4b6] hover:bg-[#009da0] text-white text-sm md:text-base font-medium rounded-full transition-colors duration-300 shadow-lg shadow-[#00b4b6]/20"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-5 h-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        Agenda tu turno
      </a>

      <a
        href="#blog"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#1e405a]/80 hover:bg-[#2b5372] border border-[#2b5372]/50 backdrop-blur-sm text-white text-sm md:text-base font-medium rounded-full transition-colors duration-300"
      >
        Conoce nuestros tratamientos
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 ml-1"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <!-- Stats -->
    <div class="flex flex-wrap items-center gap-x-12 gap-y-6 mb-8">
      <!-- <div class="flex flex-col">
        <span class="text-2xl md:text-3xl font-bold text-white mb-1">+10</span>
        <span class="text-xs md:text-sm font-medium text-gray-400"
          >Años de experiencia</span
        >
      </div> -->
      <div class="flex flex-col">
        <span class="text-2xl md:text-3xl font-bold text-white mb-1">+2000</span
        >
        <span class="text-xs md:text-sm font-medium text-gray-400"
          >Pacientes atendidos</span
        >
      </div>
      <div class="flex flex-col">
        <span class="text-2xl md:text-3xl font-bold text-white mb-1">100%</span>
        <span class="text-xs md:text-sm font-medium text-gray-400"
          >Compromiso</span
        >
      </div>
    </div>
  </main>

  <!-- Navigation Dots -->
  <div
    class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-20 flex gap-3"
  >
    <button
      class="carousel-dot w-3 h-3 rounded-full bg-white transition-all duration-300"
      data-index="0"
      aria-label="Ir a imagen 1"></button>
    <button
      class="carousel-dot w-3 h-3 rounded-full bg-white/40 hover:bg-white/70 transition-all duration-300"
      data-index="1"
      aria-label="Ir a imagen 2"></button>
    <button
      class="carousel-dot w-3 h-3 rounded-full bg-white/40 hover:bg-white/70 transition-all duration-300"
      data-index="2"
      aria-label="Ir a imagen 3"></button>
  </div>
</header>

<script>
  let currentIndex = 0;
  let autoSlideInterval: number;

  const images = document.querySelectorAll(
    ".carousel-image",
  ) as NodeListOf<HTMLElement>;
  const dots = document.querySelectorAll(
    ".carousel-dot",
  ) as NodeListOf<HTMLElement>;

  function showSlide(index: number) {
    // Hide all images
    images.forEach((img) => {
      img.classList.remove("opacity-100");
      img.classList.add("opacity-0");
    });

    // Show current image
    images[index].classList.remove("opacity-0");
    images[index].classList.add("opacity-100");

    // Update dots
    dots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.remove("bg-white/40", "hover:bg-white/70");
        dot.classList.add("bg-white");
      } else {
        dot.classList.remove("bg-white");
        dot.classList.add("bg-white/40", "hover:bg-white/70");
      }
    });

    currentIndex = index;
  }

  function nextSlide() {
    if (images.length === 0) return;
    const next = (currentIndex + 1) % images.length;
    showSlide(next);
  }

  function startAutoSlide() {
    autoSlideInterval = window.setInterval(nextSlide, 5000);
  }

  function stopAutoSlide() {
    clearInterval(autoSlideInterval);
  }

  // Bind dots
  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const index = parseInt(dot.getAttribute("data-index") || "0");
      showSlide(index);
      stopAutoSlide();
      startAutoSlide(); // Restart interval on manual click
    });
  });

  // Start carousel
  startAutoSlide();

  // Pause on hover
  const header = document.querySelector("header");
  header?.addEventListener("mouseenter", stopAutoSlide);
  header?.addEventListener("mouseleave", startAutoSlide);
</script>
